{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "ANTIRSI_RENDERER_URL",
    "ELECTRON_RENDERER_PORT",
    "HOST",
    "PORT",
    "VITE_API_BASE_URL",
    "VITE_DEV_SERVER_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    },
    "start": {
      "dependsOn": ["build", "@antirsi/web#build"],
      "cache": false,
      "persistent": true
    }
  }
}
